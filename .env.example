# Free LLM Gateway Configuration
# Copy this file to .env and fill in your API keys

# Master key for authenticating to this gateway
MASTER_KEY=your-master-key-here

# Provider API Keys (get free keys from the links below)
# Cohere: https://dashboard.cohere.com/api-keys
# Free "Trial" API key, no credit card. 1,000 API calls/month. Non-commercial use only.
COHERE_KEY=

# Google Gemini: https://aistudio.google.com/app/apikey
# Free tier unavailable in EU/UK/Switzerland. Free-tier prompts may be used by Google to improve produ
GOOGLE_GEMINI_KEY=

# Mistral AI: https://console.mistral.ai/api-keys
# Free "Experiment" plan, no credit card. ~1B tokens/month.
MISTRAL_KEY=

# Z AI (Zhipu AI): https://open.bigmodel.cn/usercenter/apikeys
# Permanent free models, no credit card required.
Z_AI_ZHIPU_AI_KEY=

# Cerebras: https://cloud.cerebras.ai/
# Free tier, no credit card. Ultra-fast inference (~2,600 tok/s). 1M tokens/day cap.
CEREBRAS_KEY=

# Cloudflare Workers AI: https://dash.cloudflare.com/profile/api-tokens
# 10,000 Neurons/day free. 50+ models available on free tier.
CLOUDFLARE_KEY=

# GitHub Models: https://github.com/marketplace/models
# Free prototyping for all GitHub users. 45+ models. Per-request limits (8K in / 4K out).
GITHUB_KEY=

# Groq: https://console.groq.com/keys
# Free tier, no credit card. Ultra-fast LPU inference.
GROQ_KEY=

# Hugging Face: https://huggingface.co/settings/tokens
# Free Serverless Inference API + ~$0.10/month free credits. Thousands of models.
HUGGINGFACE_KEY=

# Kilo Code: https://kilo.ai
# Free models with no credit card required. `kilo-auto/free` auto-router routes to minimax/minimax-m2.
KILO_CODE_KEY=

# LLM7.io: https://token.llm7.io
# Zero-friction API gateway. No registration needed for basic access. 30+ models.
LLM7.IO_KEY=

# ModelScope: https://modelscope.cn/my/myaccesstoken
# Free API-Inference for registered users. Requires Alibaba Cloud account binding + real-name verifica
MODELSCOPE_KEY=

# NVIDIA NIM: https://build.nvidia.com/explore/discover
# Free with NVIDIA Developer Program membership. 100+ models. No daily token cap.
NVIDIA_NIM_KEY=

# Ollama Cloud: https://ollama.com/settings/keys
# Free tier with qualitative usage limits. 400+ models from Ollama library. Not OpenAI SDK-compatible;
OLLAMA_KEY=

# OpenRouter: https://openrouter.ai/keys
# 35+ free models (marked with `:free` suffix). OpenAI SDK-compatible.
OPENROUTER_KEY=

# SiliconFlow: https://cloud.siliconflow.cn/account/ak
# Free tier with 14 CNY signup credits. Permanently free models available.
SILICONFLOW_KEY=

# Cloudflare requires account ID
CLOUDFLARE_ACCOUNT_ID=

# Server settings
HOST=0.0.0.0
PORT=8080

# Rate limit settings (requests per minute per provider, 0 = unlimited)
DEFAULT_RPM_LIMIT=0

# Cache settings
CACHE_TTL=1800
CACHE_MAX_SIZE=1000

# Queue settings
BATCH_MAX_SIZE=10